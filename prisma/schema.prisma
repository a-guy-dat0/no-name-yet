// Prisma schema — {no name yet}
// SQLite for simplicity. Swap provider to "postgresql" later if you grow.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- NextAuth standard tables ----------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- App tables ----------
model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())

  // Subscription / tier state
  tier                Int       @default(0)          // 0,1,2,3
  paypalSubscriptionId String?  @unique
  subscriptionStatus  String?                       // ACTIVE, CANCELLED, SUSPENDED, etc.
  subscriptionRenewsAt DateTime?

  accounts      Account[]
  sessions      Session[]
  questions     Question[]
}

model Question {
  id        String   @id @default(cuid())
  userId    String
  prompt    String
  answer    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
