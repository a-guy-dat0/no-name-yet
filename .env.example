# ===== {no name yet} environment variables =====
# Copy this file to .env and fill in the values.

# --- App ---
# Public URL where the site is served (no trailing slash). For local dev: http://localhost:3000
NEXTAUTH_URL="https://your-domain.com"
# Random 32+ character secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# --- Database (SQLite by default, no setup needed) ---
DATABASE_URL="file:./dev.db"

# --- Google OAuth ---
# Get these from https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI must be: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Ollama ---
# Where Ollama is reachable. On the same VPS, this is http://127.0.0.1:11434
OLLAMA_BASE_URL="http://127.0.0.1:11434"
# The exact model tag pulled with: ollama run hf.co/Jiunsong/supergemma4-26b-uncensored-gguf-v2
OLLAMA_MODEL="hf.co/Jiunsong/supergemma4-26b-uncensored-gguf-v2"

# --- PayPal ---
# Get these from https://developer.paypal.com → Apps & Credentials
# Use the LIVE credentials for production, SANDBOX while testing.
PAYPAL_ENV="sandbox"          # "sandbox" or "live"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# Webhook ID from https://developer.paypal.com → Apps & Credentials → your app → Webhooks
PAYPAL_WEBHOOK_ID=""
# Plan IDs you create in the PayPal dashboard (see DEPLOYMENT.md step 7)
PAYPAL_PLAN_ID_TIER1=""
PAYPAL_PLAN_ID_TIER2=""
PAYPAL_PLAN_ID_TIER3=""

# Public copy used in the browser by the PayPal SDK (must match PAYPAL_CLIENT_ID)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
NEXT_PUBLIC_PAYPAL_PLAN_ID_TIER1=""
NEXT_PUBLIC_PAYPAL_PLAN_ID_TIER2=""
NEXT_PUBLIC_PAYPAL_PLAN_ID_TIER3=""
